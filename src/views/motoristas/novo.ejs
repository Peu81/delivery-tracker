<div class="formulario">
  <h1>Novo Motorista</h1>

  <% if (typeof erro !== 'undefined' && erro){ %> 
    <div class="erros"> <%= erro %> </div>
   <% } %>

  <form method="POST" action="/painel/motoristas">
    <div class="form-group">
      <label for="nome">Nome</label>
      <input
        type="text"
        id="nome"
        name="nome"
        value="<%= typeof motorista !== 'undefined' && motorista.nome ? motorista.nome : '' %>"
        placeholder="Nome completo"
        required
      >
    </div>

    <div class="form-group">
      <label for="cpf">CPF</label>
      <input
        type="text"
        id="cpf"
        name="cpf"
        value="<%= typeof motorista !== 'undefined' && motorista.cpf ? motorista.cpf : '' %>"
        placeholder="Digite apenas números"
        required
      >
    </div>

    <div class="form-group">
      <label for="placa">Placa do veículo</label>
      <input
        type="text"
        id="placaVeiculo"
        name="placaVeiculo"
        value="<%= typeof motorista !== 'undefined' && motorista.placaVeiculo ? motorista.placaVeiculo : '' %>"
        placeholder="Exemplo: AAAA-111"
        required
      >
    </div>

    <div class="form-actions">
      <a href="/painel/motoristas" class="botao">Cancelar</a>
      <button type="submit" class="botao">Criar Motorista</button>
    </div>
  </form>
</div>